{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "//#typecheck:root": {
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "oxfmt.config.ts"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}
