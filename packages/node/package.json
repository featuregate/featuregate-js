{
  "name": "@featuregate/node",
  "version": "0.2.0",
  "description": "Official Node.js SDK for FeatureGate.",
  "keywords": [
    "feature-flags",
    "feature-toggle",
    "nodejs",
    "sdk",
    "typescript"
  ],
  "homepage": "https://featuregate.dev/docs",
  "bugs": {
    "url": "https://github.com/featuregate/featuregate-js/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/featuregate/featuregate-js.git",
    "directory": "packages/node"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint",
    "prepack": "npm run build",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.5",
    "@featuregate/evaluation": "*",
    "@featuregate/tsconfig": "*",
    "@types/node": "24.13.3",
    "publint": "0.3.21",
    "tsdown": "0.22.9",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
