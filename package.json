{
  "name": "featuregate-js",
  "version": "0.0.0",
  "private": true,
  "description": "Official JavaScript and TypeScript SDKs for FeatureGate.",
  "homepage": "https://featuregate.dev",
  "bugs": {
    "url": "https://github.com/featuregate/featuregate-js/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/featuregate/featuregate-js.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "format": "oxfmt --write .",
    "lint": "oxlint . --deny-warnings",
    "release:validate": "node scripts/release/release.mjs",
    "test": "npm run test:release && turbo run test",
    "test:release": "node --test scripts/release/*.test.mjs",
    "typecheck": "turbo run typecheck typecheck:root",
    "typecheck:root": "tsc"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "semver": "7.8.5",
    "turbo": "2.10.5",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=24.18.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.18.0"
}
